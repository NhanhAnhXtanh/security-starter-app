{
  "info": {
    "name": "DB React Springboot BE - Full",
    "description": "Auth + phân quyền (no token / ROLE_USER / ROLE_ADMIN) + CRUD Catalog/Meta + Admin Starter (/api/admin/sec/**). Token tự lưu vào collection var qua test script.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8081" },
    { "key": "username", "value": "testuser01" },
    { "key": "password", "value": "P@ssw0rd!" },
    { "key": "newPassword", "value": "N3wP@ssw0rd!" },
    { "key": "email", "value": "testuser01@example.com" },
    { "key": "userAccessToken", "value": "" },
    { "key": "userRefreshToken", "value": "" },
    { "key": "adminAccessToken", "value": "" },
    { "key": "adminRefreshToken", "value": "" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "tagId", "value": "" },
    { "key": "domainId", "value": "" },
    { "key": "organizationId", "value": "" },
    { "key": "metaSourceId", "value": "" }
  ],
  "item": [
    {
      "name": "0. Auth flow (user)",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api","auth","register"] },
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\",\n  \"email\": \"{{email}}\",\n  \"firstName\": \"Test\",\n  \"lastName\": \"User\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Register 201 hoặc 409', () => pm.expect([201,409]).to.include(pm.response.code));"
          ]}}]
        },
        {
          "name": "Login user",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] },
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Login user 200', () => pm.response.to.have.status(200));",
            "const j = pm.response.json();",
            "pm.collectionVariables.set('userAccessToken', j.accessToken);",
            "pm.collectionVariables.set('userRefreshToken', j.refreshToken);",
            "pm.collectionVariables.set('accessToken', j.accessToken);",
            "pm.collectionVariables.set('refreshToken', j.refreshToken);"
          ]}}]
        },
        {
          "name": "Login admin (seeded)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] },
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Login admin 200', () => pm.response.to.have.status(200));",
            "const j = pm.response.json();",
            "pm.collectionVariables.set('adminAccessToken', j.accessToken);",
            "pm.collectionVariables.set('adminRefreshToken', j.refreshToken);"
          ]}}]
        },
        {
          "name": "Authenticate check (user)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userAccessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/authenticate", "host": ["{{baseUrl}}"], "path": ["api","authenticate"] }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('200', () => pm.response.to.have.status(200));"
          ]}}]
        },
        {
          "name": "Refresh (user)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/refresh", "host": ["{{baseUrl}}"], "path": ["api","auth","refresh"] },
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{userRefreshToken}}\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('200', () => pm.response.to.have.status(200));",
            "const j = pm.response.json();",
            "pm.collectionVariables.set('userAccessToken', j.accessToken);",
            "pm.collectionVariables.set('userRefreshToken', j.refreshToken);"
          ]}}]
        },
        {
          "name": "Change password",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userAccessToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/auth/change-password", "host": ["{{baseUrl}}"], "path": ["api","auth","change-password"] },
            "body": { "mode": "raw", "raw": "{\n  \"currentPassword\": \"{{password}}\",\n  \"newPassword\": \"{{newPassword}}\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('204', () => pm.response.to.have.status(204));",
            "const oldP = pm.collectionVariables.get('password');",
            "const newP = pm.collectionVariables.get('newPassword');",
            "pm.collectionVariables.set('password', newP);",
            "pm.collectionVariables.set('newPassword', oldP);"
          ]}}]
        },
        {
          "name": "Logout (user)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{userAccessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/auth/logout", "host": ["{{baseUrl}}"], "path": ["api","auth","logout"] }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('204', () => pm.response.to.have.status(204));"
          ]}}]
        }
      ]
    },
    {
      "name": "1. Authorization probe",
      "item": [
        {
          "name": "No token → /api/tags (401)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/tags", "host": ["{{baseUrl}}"], "path": ["api","tags"] }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Unauthenticated → 401', () => pm.response.to.have.status(401));"
          ]}}]
        },
        {
          "name": "User token → /api/admin/sec/roles (403)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userAccessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/admin/sec/roles", "host": ["{{baseUrl}}"], "path": ["api","admin","sec","roles"] }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Non-admin → 403', () => pm.response.to.have.status(403));"
          ]}}]
        },
        {
          "name": "Admin token → /api/admin/sec/roles (200)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminAccessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/admin/sec/roles", "host": ["{{baseUrl}}"], "path": ["api","admin","sec","roles"] }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Admin → 200', () => pm.response.to.have.status(200));"
          ]}}]
        },
        {
          "name": "User token → /api/tags GET (200 hoặc 403)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userAccessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/tags", "host": ["{{baseUrl}}"], "path": ["api","tags"] }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Authenticated → 200 (đọc public) hoặc 403 (chưa cấp permission)', () => pm.expect([200,403]).to.include(pm.response.code));",
            "console.log('Tag READ permission for ROLE_USER:', pm.response.code === 200 ? 'GRANTED' : 'DENIED');"
          ]}}]
        },
        {
          "name": "User token → /api/tags POST (403 expected)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userAccessToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/tags", "host": ["{{baseUrl}}"], "path": ["api","tags"] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"probe-tag\",\n  \"slug\": \"probe-tag\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('User CREATE Tag → 200/201 (granted) hoặc 403 (denied)', () => pm.expect([200,201,403]).to.include(pm.response.code));",
            "console.log('Tag CREATE permission for ROLE_USER:', [200,201].includes(pm.response.code) ? 'GRANTED' : 'DENIED');"
          ]}}]
        }
      ]
    },
    {
      "name": "2. Catalog CRUD (Tag) — admin",
      "item": [
        {
          "name": "List tags",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminAccessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/tags?page=0&size=20", "host": ["{{baseUrl}}"], "path": ["api","tags"], "query": [{"key":"page","value":"0"},{"key":"size","value":"20"}] }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('200', () => pm.response.to.have.status(200));"
          ]}}]
        },
        {
          "name": "Create tag",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminAccessToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/tags", "host": ["{{baseUrl}}"], "path": ["api","tags"] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"qa-tag\",\n  \"slug\": \"qa-tag\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('201', () => pm.response.to.have.status(201));",
            "const j = pm.response.json();",
            "if (j.id) pm.collectionVariables.set('tagId', j.id);"
          ]}}]
        },
        {
          "name": "Get tag by id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminAccessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/tags/{{tagId}}", "host": ["{{baseUrl}}"], "path": ["api","tags","{{tagId}}"] }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('200', () => pm.response.to.have.status(200));"
          ]}}]
        },
        {
          "name": "Update tag",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminAccessToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/tags/{{tagId}}", "host": ["{{baseUrl}}"], "path": ["api","tags","{{tagId}}"] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"qa-tag-updated\",\n  \"slug\": \"qa-tag\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('200', () => pm.response.to.have.status(200));"
          ]}}]
        },
        {
          "name": "Delete tag",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminAccessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/tags/{{tagId}}", "host": ["{{baseUrl}}"], "path": ["api","tags","{{tagId}}"] }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('204', () => pm.response.to.have.status(204));"
          ]}}]
        }
      ]
    },
    {
      "name": "3. Catalog (Domain + Organization)",
      "item": [
