            ],
            "url": { "raw": "{{baseUrl}}/api/app/organizations", "host": ["{{baseUrl}}"], "path": ["api","app","organizations"] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"qa-org\",\n  \"slug\": \"qa-org\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "if (pm.response.code === 201) pm.collectionVariables.set('organizationId', pm.response.json().id);"
          ]}}]
        }
      ]
    },
    {
